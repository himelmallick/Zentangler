Package: Zentangler
Title: Multi-View Mediation Analysis for MultiAssayExperiment Data
Version: 0.1.0
Authors@R: c(
    person("Nalin", "Arora", email = "naa4050@med.cornell.edu", role = "aut"),
    person("Himel", "Mallick", email = "him4004@med.cornell.edu",
        role = c("aut", "cre", "cph"),
        comment = c(ORCID = "0000-0003-4956-2429"))
